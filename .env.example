# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3000
APP_PUBLIC_URL=https://seudominio.com.br
CORS_ORIGIN=https://seudominio.com.br

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=licitabrasil
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_DB=licitabrasil

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=lb_sid
SESSION_TTL_SECONDS=604800

# ── Password Recovery ─────────────────────────────────────────────────────────
PASSWORD_RECOVERY_TOKEN_TTL_SECONDS=1800

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_SEED_EMAIL=admin@seudominio.com.br
ADMIN_SEED_PASSWORD=TROQUE_AQUI
ADMIN_SEED_NAME=Administrador Geral

# ── PNCP ─────────────────────────────────────────────────────────────────────
PNCP_ENABLED=false
# PNCP_BASE_URL=https://treina.pncp.gov.br/api/pncp/v1

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=TROQUE_AQUI
SMTP_FROM=noreply@seudominio.com.br

# ── Auction automation ────────────────────────────────────────────────────────
AUCTION_AUTO_CLOSE_INTERVAL_MS=30000
ANTI_SNIPING_WINDOW_MS=60000
ANTI_SNIPING_EXTENSION_MS=120000
